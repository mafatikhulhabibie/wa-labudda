# Server
PORT=3000
NODE_ENV=development

# MySQL (required)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=wa
MYSQL_PASSWORD=secret
MYSQL_DATABASE=wa_gateway

# Run db/schema.sql on startup (CREATE TABLE IF NOT EXISTS)
DB_AUTO_MIGRATE=true

# Auth — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN_SEC=604800

# HTTPS reverse proxy: set COOKIE_SECURE=true so session cookie is Secure
COOKIE_SECURE=false
# SESSION_COOKIE_NAME=wg_session

# First admin when `users` is empty (one-time)
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me-immediately

# Multi-session storage (each session: sessions/<session_id>/ Baileys auth files)
SESSIONS_ROOT=./sessions

# QR PNG files: qr/<session_id>.png
QR_DIR=./qr

# Anti-ban: random delay before each send (milliseconds), inclusive range
SEND_DELAY_MIN_MS=3000
SEND_DELAY_MAX_MS=10000

# Send attempts (default 4 = 1 try + 3 retries)
SEND_MAX_ATTEMPTS=4
SEND_RETRY_BACKOFF_MS=1500

# Broadcast guard per device (anti-spam)
BROADCAST_MAX_PER_MINUTE_PER_DEVICE=8
BROADCAST_MAX_PER_HOUR_PER_DEVICE=120
BROADCAST_MAX_PER_DAY_PER_DEVICE=600

# Rate limit: max requests per IP per window (all /api/*)
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000

# Logging
LOG_LEVEL=info

# Optional: POST incoming message notifications (JSON) for messages.upsert
# WEBHOOK_INCOMING_MESSAGE_URL=https://example.com/hooks/whatsapp
# Device webhook payload mode: default | fonnte
# WEBHOOK_PAYLOAD_MODE=default

# Queue driver label (memory today; swap for redis/bullmq later)
QUEUE_DRIVER=memory
